# Copie pra ".env" nesta mesma pasta e preencha com os valores reais
# (mesmos do .env.local do app principal — Project Settings > API no
# Supabase). Nunca commitar o ".env" de verdade.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Nome do compartilhamento da impressora no Windows (Painel de Controle >
# Dispositivos e Impressoras > botão direito > Propriedades > Compartilhamento).
IMPRESSORA_COMPARTILHAMENTO=ELGIN i8
