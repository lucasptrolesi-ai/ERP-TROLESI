# Copie pra ".env" nesta mesma pasta e preencha com os valores reais
# (mesmos do .env.local do app principal e do print-agent/.env — Project
# Settings > API no Supabase). Nunca commitar o ".env" de verdade.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Caminho local do arquivo real do GMax nesta máquina (SERVIDOR). O agente
# NUNCA lê esse arquivo direto — sempre copia pra um arquivo temporário
# antes de ler, e apaga a cópia depois.
CAMINHO_GMAX_FDB=C:\GMax\GMaxERP.FDB

# De quanto em quanto tempo checar por solicitações novas (ms). A leitura
# do Firebird demora mais que imprimir um cupom, por isso o intervalo
# default é maior que o do print-agent.
INTERVALO_POLLING_MS=5000
